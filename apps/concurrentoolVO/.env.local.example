# Kopieer dit bestand naar .env.local en vul uw Anthropic API-sleutel in.
# .env.local wordt NIET mee-gecommit (staat in .gitignore via *.local).
#
# LET OP: Dit is een intern instrument — de API-sleutel is zichtbaar in de browser.
# Gebruik dit instrument alleen op vertrouwde Cito-netwerken.

# Anthropic API-sleutel (verplicht voor AI-functies)
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# Sla authenticatie over in dev-modus (geen Supabase vereist)
VITE_SKIP_AUTH=true

# --- OPTIONEEL: lokale Supabase-verbinding (zet je in als je echte data wil zien) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# --- OPTIONEEL: dev auto-login (laat je voorbij login-scherm zonder elke keer te typen) ---
# Zet beide regels aan + zet VITE_SKIP_AUTH op false (of haal die regel weg).
# Werkt ALLEEN lokaal — productie-Vercel kent deze env-vars niet, dus geen security-risico.
# VITE_DEV_AUTOLOGIN_EMAIL=jouw@email.nl
# VITE_DEV_AUTOLOGIN_PASSWORD=jouw-wachtwoord
