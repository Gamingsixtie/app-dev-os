# Local environment variables for concurrentoolVO
# Copy this file to .env.local (gitignored) and fill in dev-Supabase + Anthropic credentials.
#
# OTAP framework env-var pattern (single name, scoped values per Vercel environment):
#   - Local development reads from .env.local (this file's real version).
#   - Vercel "Preview" environment uses dev-Supabase + dev-Anthropic values.
#   - Vercel "Production" environment uses prod-Supabase + prod-Anthropic values (set in Vercel dashboard).
#
# DO NOT use _PROD/_DEV suffix variants — that scatters truth across multiple variables.
# See ../../code_context/otap.md § "Environment variables" for the full pattern.
#
# LET OP: Dit is een intern instrument — de API-sleutel is zichtbaar in de browser.
# Gebruik alleen op vertrouwde Cito-netwerken.

# --- Anthropic API (required for AI-intake + AI-advies features) ---
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Supabase (dev project: concurrentool-dev) ---
# Required for any feature that reads/writes user data, school profiles, or auth.
# When VITE_SKIP_AUTH=true (below), Supabase auth is skipped — but data writes still need these.
VITE_SUPABASE_URL=https://your-dev-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- Sentry (optional, error tracking) ---
# Same DSN can be used across environments — Sentry tags by Vercel env automatically.
# SENTRY_DSN=

# --- DEV-ONLY: skip Supabase authentication ---
# Useful for local testing without setting up Supabase Auth users.
# Production Vercel does NOT see this — even if you forget, prod always requires auth.
VITE_SKIP_AUTH=true

# --- DEV-ONLY: auto-login (with VITE_SKIP_AUTH=false) ---
# Lets you skip the login screen during local dev. Production Vercel does NOT see these,
# so no security risk to leave them set locally.
# VITE_DEV_AUTOLOGIN_EMAIL=jouw@email.nl
# VITE_DEV_AUTOLOGIN_PASSWORD=jouw-wachtwoord
