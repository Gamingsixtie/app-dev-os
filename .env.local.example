# Kopieer dit bestand naar .env.local en vul uw Anthropic API-sleutel in.
# .env.local wordt NIET mee-gecommit (staat in .gitignore via *.local).
#
# LET OP: Dit is een intern instrument — de API-sleutel is zichtbaar in de browser.
# Gebruik dit instrument alleen op vertrouwde Cito-netwerken.

# Anthropic API-sleutel (verplicht voor AI-functies)
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...

# Sla authenticatie over in dev-modus (geen Supabase vereist)
VITE_SKIP_AUTH=true
