{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(npm run *)",
      "Bash(npm test:*)",
      "Bash(npm install)",
      "Bash(pnpm run *)",
      "Bash(pnpm test:*)",
      "Bash(pnpm install)",
      "Bash(pnpm remove *)",
      "Bash(yarn run *)",
      "Bash(yarn test:*)",
      "Bash(yarn install)",
      "Bash(bun run *)",
      "Bash(bun test:*)",
      "Bash(bun install)",
      "Bash(npx *)",
      "Bash(pnpm dlx *)",
      "Bash(pnpm exec *)",
      "Bash(pnpm tsc *)",
      "Bash(pnpm biome *)",
      "Bash(biome *)",
      "Bash(node *)",
      "Bash(supabase *)",
      "Bash(vercel *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo view *)",
      "Bash(gh release view *)",
      "Bash(gh release list *)",
      "Bash(gh auth status)",
      "Bash(sentry-cli *)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go run:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(uv run *)",
      "Bash(poetry run *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote *)",
      "Bash(git tag --list *)",
      "Bash(git config --get *)",
      "Bash(git rev-list *)",
      "Read(*)",
      "Read(.env.example)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(test/**)",
      "Edit(docs/**)",
      "Edit(scripts/**)",
      "Edit(code_context/**)",
      "Edit(brand_context/**)",
      "Edit(context/**)",
      "Edit(projects/**)",
      "Edit(apps/**)",
      "Edit(.claude/**)",
      "Edit(cron/**)",
      "Edit(*.md)",
      "Edit(*.json)",
      "Edit(*.toml)",
      "Edit(*.yaml)",
      "Edit(*.yml)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(test/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(code_context/**)",
      "Write(brand_context/**)",
      "Write(context/**)",
      "Write(projects/**)",
      "Write(apps/**)",
      "Write(.claude/**)",
      "Write(cron/**)",
      "Write(*.md)",
      "Write(*.json)",
      "Write(*.toml)",
      "Write(*.yaml)",
      "Write(*.yml)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf .:*)",
      "Bash(rmdir /s *)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push origin production*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard origin/main*)",
      "Bash(git reset --hard origin/master*)",
      "Bash(npm uninstall *)",
      "Bash(yarn remove *)",
      "Bash(pip uninstall *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(chmod 777 *)",
      "Read(.env)",
      "Read(.env.production)",
      "Read(.env.development.local)",
      "Read(.env.test.local)",
      "Read(**/secrets/**)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Edit(package-lock.json)",
      "Edit(pnpm-lock.yaml)",
      "Edit(yarn.lock)",
      "Edit(bun.lockb)",
      "Edit(poetry.lock)",
      "Edit(uv.lock)",
      "Edit(Cargo.lock)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-ccnotify.js\" UserPromptSubmit"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-sync-prompt.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-ccnotify.js\" Stop"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-sync-stop.js\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/run-ccnotify.js\" Notification"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-sync-notify.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-sync.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-sync-tool.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/branch-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/secret-scan.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/dangerous-bash.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/lockfile-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/typecheck-guard.js",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
